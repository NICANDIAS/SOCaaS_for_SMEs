# ══════════════════════════════════════════════════════════════
# TIGARSEC SOCaaS — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# NEVER commit .env to git — it is in .gitignore
# ══════════════════════════════════════════════════════════════

# ── Elasticsearch ──────────────────────────────────────────────
ELASTIC_PASSWORD=changeme

# ── Kibana ─────────────────────────────────────────────────────
KIBANA_SYSTEM_PASSWORD=changeme

# ── n8n ────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ── TheHive ────────────────────────────────────────────────────
# API key generated inside TheHive after first login
THEHIVE_API_KEY=your-thehive-api-key-here

# ── AbuseIPDB ──────────────────────────────────────────────────
# Free API key from https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your-abuseipdb-api-key-here

# ── Notifications ──────────────────────────────────────────────
# CallMeBot WhatsApp API key
# Activate at: https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=your-callmebot-api-key-here
WHATSAPP_PHONE=447XXXXXXXXX

# ── Wazuh ──────────────────────────────────────────────────────
# Manager IP — used in agent install commands
WAZUH_MANAGER_IP=your-server-ip-here


BEATS_PASSWORD=changeme
